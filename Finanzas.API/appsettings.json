{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "CategorySettings": {
        "AllowedColors": [ "Azul", "Verde", "Gris", "Cafe", "Negro" ]
    },
    "OpenTelemetry": {
        "ServiceName": "Finanzas.API",
        "CollectorEndpoint": "http://otel-collector:4317",
        "Environment": "Development",
        "EnableSqlInstrumentation": true
    }
}
